{
  "expo": {
    "name": "CMR Mobile",
    "slug": "cmr-mobile",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "splash": {
      "image": "./assets/logo.png",
      "resizeMode": "contain",
      "backgroundColor": "#003566"
    },
    "updates": {
      "fallbackToCacheTimeout": 0
    },
    "assetBundlePatterns": [
      "**/*"
    ],
    "android": {
      "package": "com.cmr.mobile"
    },
    "ios": {
      "supportsTablet": true
    }
  }
}
